        <mxCell id="legend" value="&lt;b&gt;图例&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;■&lt;/font&gt; 绿块=电源输入&amp;nbsp;&amp;nbsp;&lt;font color=&quot;#b85450&quot;&gt;■&lt;/font&gt; 红块=电源输出&lt;br&gt;&lt;font color=&quot;#000000&quot;&gt;━ 黑实线 = 电源&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#1565C0&quot;&gt;━ 蓝实线 = 以太网/点云&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#EF6C00&quot;&gt;┅ 橙虚线 = PWM 信号&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#8E24AA&quot;&gt;┅ 紫虚线 = 外设信号(SBUS/MAVLink/USB)&lt;/font&gt;&lt;br&gt;接头公母：输出=母头 / 输入=公头" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;spacing=8;" parent="1" vertex="1">
          <mxGeometry x="3250" y="880" width="800" height="220" as="geometry" />
        </mxCell>
        <mxCell id="summary" value="&lt;b&gt;接口对应汇总&lt;/b&gt;&lt;br&gt;• HM30 → RC IN(SBUS) + TEL1(MAVLink) + USB视频(Jetson)；12V←BEC-2&lt;br&gt;• A8 mini → HM30 LAN&amp;PWR（供电+SBUS+RTSP 视频，经图传回传，v4 接法）&lt;br&gt;• Mid-360 → ETH-P1(T568B)；12V←BEC-1（独立地）&lt;br&gt;• UBEC→Jetson(12V) · PM02D→飞控(5.5V) · 飞控 PWM M1~M8→8 ESC&lt;br&gt;&lt;b&gt;线规：&lt;/b&gt;主干 8AWG · 电池/PDB 段 10AWG · PDB→ESC 12AWG · ESC→电机 20AWG" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=11;fillColor=#f5f5f5;strokeColor=#666666;spacing=8;" parent="1" vertex="1">
          <mxGeometry x="3250" y="1130" width="800" height="250" as="geometry" />
